# Tenant selection (demo | pib | aia)
EXPO_PUBLIC_TENANT=demo

# Google Maps API key — used by native build config (app.json $GOOGLE_MAPS_API_KEY)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps API key — available at JS runtime via process.env
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
