# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

# Which tenant to load (demo | pib | aia)
EXPO_PUBLIC_TENANT=pib

# Google Maps API key — needed for Android reverse geocoding in production builds
# Not needed for Expo Go testing (Expo Go has its own key)
# Get yours: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps SDK for Android, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
